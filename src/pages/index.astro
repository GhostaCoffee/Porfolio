---
import Base from '../layouts/Base.astro';
---
<Base title="Muhammad Ahmad Khan">
  <div style="padding: 0 20px;">
    <div style="max-width: 1100px; margin: 0 auto; padding: 40px 0;">

      <!-- HEADER -->
      <header style="margin-bottom: 60px;" class="anim-fade-down">
        <h1 style="font-size:42px;font-weight:700;margin-bottom:10px;position:relative;display:inline-block;" class="name-heading">
          Muhammad Ahmad Khan
        </h1>
        <div style="font-size:18px;color:var(--accent);margin-bottom:24px;" class="anim-fade-in delay-2">
          Gen AI Engineer | Python Developer
        </div>

        <!-- NAV LINKS: Blog + Social Icons -->
        <div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap;" class="anim-fade-in delay-3">

          <a href="/blog" class="blog-nav-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            Blog
          </a>

          <span style="width:1px;height:20px;background:rgba(255,255,255,0.12);"></span>

          <div style="display:flex;align-items:center;gap:14px;">
            <a href="https://github.com/GhostaCoffee/" target="_blank" class="icon-link" title="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
            </a>
            <a href="https://linkedin.com/in/ahmad-is-a-dev/" target="_blank" class="icon-link" title="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg>
            </a>
            <a href="https://www.youtube.com/@mahmadkhann" target="_blank" class="icon-link" title="YouTube">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.54-.123 1.082-.235 1.466a2.01 2.01 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.01 2.01 0 0 1-1.415-1.419c-.111-.384-.184-.936-.24-1.558l-.014-.161-.003-.043-.012-.153-.007-.107-.022-.26-.005-.065A14.236 14.236 0 0 1 2 8v-.105c0-.32.01-1.175.07-2.012l.006-.082.006-.081.022-.273.009-.104c.048-.519.119-1.023.22-1.402A2.01 2.01 0 0 1 3.742 2.4c.486-.13 1.544-.21 2.654-.26l.17-.007.172-.006.086-.003.171-.007A99.788 99.788 0 0 1 7.858 2h.193zM6.4 5.209v4.818l4.157-2.408L6.4 5.209z"/></svg>
            </a>
            <a href="https://x.com/mahmadkhann_" target="_blank" class="icon-link" title="X (Twitter)">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 300 300"><path d="M178.57 127.15L290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300h26.46l102.4-116.59L176.66 300H266L178.57 127.15zm-36.26 41.26-11.87-16.63L36.07 19.48h40.64l76.21 106.74 11.87 16.63 99.06 138.89h-40.64l-80.9-113.33z"/></svg>
            </a>
            <a href="mailto:mahmadkhan.business@gmail.com" class="icon-link" title="Email">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z"/></svg>
            </a>
          </div>
        </div>
      </header>

      <!-- TERMINAL CARD -->
      <section style="margin-bottom:60px;" class="anim-fade-up delay-2">
        <div class="terminal-card">
          <div class="terminal-topbar">
            <div style="width:12px;height:12px;border-radius:50%;background:#ff5f57;"></div>
            <div style="width:12px;height:12px;border-radius:50%;background:#febc2e;"></div>
            <div style="width:12px;height:12px;border-radius:50%;background:#28c840;"></div>
            <span style="margin-left:8px;font-size:12px;color:#6e7681;font-family:'Courier New',monospace;letter-spacing:0.5px;">ahmad@portfolio ~ whoami</span>
          </div>
          <div class="terminal-body" id="terminalBody"></div>
        </div>
      </section>

      <!-- SKILLS -->
      <section style="margin-bottom:60px;" class="anim-fade-up delay-3">
        <h2 class="section-heading">Skills</h2>
        <div style="display:flex;flex-wrap:wrap;gap:12px;margin-top:20px;">
          {['Gen AI','Python','JavaScript','NLP','RAG Systems','Web Development','Front-End Development',
            'Automation','React','HTML/CSS','Git','Ollama','Docker','GoLang','Streamlit','llama-index',
            'Lang-Chain','Hugging-Face','Scikit-learn','NLTK','PyCharm','WSL','Django',
            'Prompt Engineering','QDrant','LLMs','vim','GitHub','neovim'].map(s => (
            <span class="skill-tag">{s}</span>
          ))}
        </div>
      </section>

      <!-- PROJECTS -->
      <section style="margin-bottom:60px;" class="anim-fade-up delay-3">
        <h2 class="section-heading">Projects</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:30px;margin-top:20px;">

          <div class="project-card">
            <div style="padding:20px;position:relative;z-index:1;">
              <h3 style="font-size:20px;font-weight:600;margin-bottom:10px;">AI RAG Chatbot</h3>
              <p style="color:var(--text-secondary);font-size:14px;margin-bottom:15px;">Chatbot that uses RAG – Retrieval Augmented Generation to answer questions based on data you feed it (specifically a PDF). Streamlit was used as the UI.</p>
              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;">
                {['Python','Streamlit','RAG','PyPDF2','Scikit-learn','Ollama','nltk'].map(t => (
                  <span style="background:rgba(255,255,255,0.08);color:var(--text-secondary);padding:4px 8px;border-radius:4px;font-size:12px;">{t}</span>
                ))}
              </div>
              <a href="https://github.com/GhostaCoffee/yajirobe-the-bot" target="_blank" class="proj-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
                GitHub
              </a>
            </div>
          </div>

          <div class="project-card">
            <div style="padding:20px;position:relative;z-index:1;">
              <h3 style="font-size:20px;font-weight:600;margin-bottom:10px;">AI Caption Generator</h3>
              <p style="color:var(--text-secondary);font-size:14px;margin-bottom:15px;">An innovative image captioning system that leverages the Google Gemini API to generate detailed, contextually accurate descriptions of uploaded images.</p>
              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;">
                {['Gemini API','Python','Streamlit','Image'].map(t => (
                  <span style="background:rgba(255,255,255,0.08);color:var(--text-secondary);padding:4px 8px;border-radius:4px;font-size:12px;">{t}</span>
                ))}
              </div>
              <a href="https://github.com/GhostaCoffee/Instagram-caption-Generator-using-Streamlit/" target="_blank" class="proj-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
                GitHub
              </a>
            </div>
          </div>

          <div class="project-card">
            <div style="padding:20px;position:relative;z-index:1;">
              <h3 style="font-size:20px;font-weight:600;margin-bottom:10px;">Voice Assistant</h3>
              <p style="color:var(--text-secondary);font-size:14px;margin-bottom:15px;">An interactive AI voice assistant built using Livekit for real-time voice interaction. Leverages locally installed LLMs for fast, private responses with natural conversation capabilities.</p>
              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;">
                {['Python','Ollama','Live-Kit'].map(t => (
                  <span style="background:rgba(255,255,255,0.08);color:var(--text-secondary);padding:4px 8px;border-radius:4px;font-size:12px;">{t}</span>
                ))}
              </div>
            </div>
          </div>

          <div class="project-card">
            <div style="padding:20px;position:relative;z-index:1;">
              <h3 style="font-size:20px;font-weight:600;margin-bottom:10px;">Reality Check AI Bot [Sir Lewis]</h3>
              <p style="color:var(--text-secondary);font-size:14px;margin-bottom:15px;">An AI reality-check bot that confronts your excuses head-on, dismantles victim thinking, and pushes you outside your comfort zone.</p>
              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;">
                {['Python','Gemini API','Streamlit','nltk','scikit-learn'].map(t => (
                  <span style="background:rgba(255,255,255,0.08);color:var(--text-secondary);padding:4px 8px;border-radius:4px;font-size:12px;">{t}</span>
                ))}
              </div>
              <a href="https://github.com/GhostaCoffee/Sir-Lewis" target="_blank" class="proj-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
                GitHub
              </a>
            </div>
          </div>

          <div class="project-card">
            <div style="padding:20px;position:relative;z-index:1;">
              <h3 style="font-size:20px;font-weight:600;margin-bottom:10px;">Personal AI Agent [AlterEgo]</h3>
              <p style="color:var(--text-secondary);font-size:14px;margin-bottom:15px;">A fully local AI agent that knows you, manages your system, tracks your goals, and remembers everything — no cloud, no subscriptions, no privacy trade-offs.</p>
              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px;">
                {['Python','Ollama','Llama3.1:8b'].map(t => (
                  <span style="background:rgba(255,255,255,0.08);color:var(--text-secondary);padding:4px 8px;border-radius:4px;font-size:12px;">{t}</span>
                ))}
              </div>
              <a href="https://github.com/GhostaCoffee/AlterEgo" target="_blank" class="proj-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
                GitHub
              </a>
            </div>
          </div>

        </div>
      </section>

      <!-- RESOURCES -->
      <section style="margin-bottom:60px;" class="anim-fade-up delay-4">
        <h2 class="section-heading">Resources</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-top:20px;">

          <div class="resource-group">
            <div style="font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);margin-bottom:16px;font-family:'Courier New',monospace;">Learning</div>
            {[
              { icon:'', name:'Anthropic Academy', desc:'Official courses on building with Claude & AI safety', url:'https://www.anthropic.com/academy' },
              { icon:'', name:'fast.ai', desc:'Practical deep learning — free, top-down, no fluff', url:'https://www.fast.ai' },
              { icon:'', name:'Karpathy — Zero to Hero', desc:'Build LLMs from scratch. Best series on the internet.', url:'https://www.youtube.com/playlist?list=PLAqhIrjkxbuWI23v9cThsA9GvCAUhRvKZ' },
            ].map(r => (
              <a href={r.url} target="_blank" style="display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;text-decoration:none;">
                <div style="width:32px;height:32px;border-radius:6px;background:rgba(100,255,218,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;">{r.icon}</div>
                <div>
                  <span style="font-size:14px;font-weight:500;color:#fff;display:block;">{r.name}</span>
                  <span style="font-size:12px;color:var(--text-secondary);display:block;margin-top:1px;">{r.desc}</span>
                </div>
              </a>
            ))}
          </div>

          <div class="resource-group">
            <div style="font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);margin-bottom:16px;font-family:'Courier New',monospace;">Tools I Use</div>
            {[
              { icon:'', name:'Ollama', desc:'Run LLMs locally — fast and private', url:'https://ollama.com' },
              { icon:'', name:'Hugging Face', desc:'Models, datasets, and spaces in one place', url:'https://huggingface.co' },
              { icon:'', name:'Qdrant', desc:'Vector database for RAG and semantic search', url:'https://qdrant.tech' },
              { icon:'', name:'LangChain', desc:'Framework for building LLM-powered apps', url:'https://python.langchain.com' },
            ].map(r => (
              <a href={r.url} target="_blank" style="display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;text-decoration:none;">
                <div style="width:32px;height:32px;border-radius:6px;background:rgba(100,255,218,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;">{r.icon}</div>
                <div>
                  <span style="font-size:14px;font-weight:500;color:#fff;display:block;">{r.name}</span>
                  <span style="font-size:12px;color:var(--text-secondary);display:block;margin-top:1px;">{r.desc}</span>
                </div>
              </a>
            ))}
          </div>

          <div class="resource-group">
            <div style="font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);margin-bottom:16px;font-family:'Courier New',monospace;">Worth Reading</div>
            {[
              { icon:'', name:"Lilian Weng's Blog", desc:'Deep dives on LLMs, agents, RL — essential reading', url:'https://lilianweng.github.io' },
              { icon:'', name:"Karpathy's Blog", desc:'Rare posts, extremely high signal', url:'https://karpathy.github.io' },
              { icon:'', name:'My YouTube', desc:'My own channel — AI, dev, and more', url:'https://www.youtube.com/@mahmadkhann' },
            ].map(r => (
              <a href={r.url} target="_blank" style="display:flex;align-items:flex-start;gap:10px;margin-bottom:12px;text-decoration:none;">
                <div style="width:32px;height:32px;border-radius:6px;background:rgba(100,255,218,0.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;">{r.icon}</div>
                <div>
                  <span style="font-size:14px;font-weight:500;color:#fff;display:block;">{r.name}</span>
                  <span style="font-size:12px;color:var(--text-secondary);display:block;margin-top:1px;">{r.desc}</span>
                </div>
              </a>
            ))}
          </div>

        </div>
      </section>

      <!-- FOOTER -->
      <footer style="margin-top:50px;padding-top:30px;border-top:1px solid rgba(255,255,255,0.1);text-align:center;">
        <div style="display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:20px;">
          <a href="https://github.com/GhostaCoffee/" target="_blank" class="icon-link" title="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
