    padding: 5px 14px;
    border: 1px solid rgba(100, 255, 218, 0.35);
    border-radius: 20px;
    background: rgba(100, 255, 218, 0.05);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    letter-spacing: 0.5px;
  }
  .blog-nav-link:hover {
    background: rgba(100, 255, 218, 0.12);
