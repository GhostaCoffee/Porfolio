    gap: 6px;
    transition: gap 0.2s ease, opacity 0.2s ease;
  }
  .proj-link:hover { gap: 10px; opacity: 0.8; }
</style>

<script>
  const lines = [
    { type: 'cmd',  text: 'cat about.json' },
    { type: 'json', text: '{' },
    { type: 'json', text: '  <key>"name"</key>:        <str>"Muhammad Ahmad Khan"</str>,' },
    { type: 'json', text: '  <key>"role"</key>:        <str>"AI Engineer & Python Developer"</str>,' },
    { type: 'json', text: '  <key>"status"</key>:      <str>"Reasercher | Student | Founder"</str>,' },
    { type: 'json', text: '  <key>"location"</key>:    <str>"Pakistan 🇵🇰"</str>,' },
    { type: 'json', text: '  <key>"focus"</key>:       <str>"AI Engineering, RAG Systems, Agnetic AI, Automation"</str>,' },
    { type: 'json', text: '  <key>"open_to"</key>:     <str>"Collabs, internships, cool ideas"</str>,' },
    { type: 'json', text: '  <key>"local_llms"</key>:  <bool>true</bool>,' },
    { type: 'json', text: '  <key>"neovim_user"</key>: <bool>true</bool>' },
    { type: 'json', text: '}' },
  ];

  const body = document.getElementById('terminalBody');
  let lineIdx = 0;
  const CHAR_DELAY = 18;
  const LINE_DELAY = 110;

  function createLineEl(line: { type: string; text: string }) {
    const div = document.createElement('div');
    div.style.cssText = 'margin-bottom:3px;font-family:"Courier New",monospace;font-size:13.5px;line-height:1.75;display:flex;align-items:center;';
    if (line.type === 'cmd') {
      const p = document.createElement('span');
      p.style.cssText = 'color:#64ffda;margin-right:8px;user-select:none;';
      p.textContent = 'ahmad@portfolio:~$';
      div.appendChild(p);
    }
    const content = document.createElement('span');
    content.style.color = line.type === 'cmd' ? '#e6edf3' : '#cdd9e5';
    div.appendChild(content);
    body!.appendChild(div);
    return content;
  }

  function renderLine(el: HTMLElement, html: string) {
    const tmp = document.createElement('div');
    tmp.innerHTML = html;
    const plain = tmp.textContent || '';
    let i = 0;
    function typeChar() {
      if (i <= plain.length) { el.textContent = plain.slice(0, i++); setTimeout(typeChar, CHAR_DELAY); }
      else { el.innerHTML = html; setTimeout(nextLine, LINE_DELAY); }
    }
    typeChar();
  }

  function nextLine() {
    if (lineIdx >= lines.length) {
      const cursor = document.createElement('span');
      cursor.style.cssText = 'display:inline-block;width:8px;height:14px;background:#64ffda;animation:blink 1s step-end infinite;vertical-align:middle;margin-left:4px;';
      body!.appendChild(cursor);
      return;
    }
    const line = lines[lineIdx++];
    const colored = line.text
      .replace(/<key>(.*?)<\/key>/g, (_, v) => `<span style="color:#64ffda">${v}</span>`)
      .replace(/<str>(.*?)<\/str>/g, (_, v) => `<span style="color:#a5d6ff">${v}</span>`)
      .replace(/<bool>(.*?)<\/bool>/g, (_, v) => `<span style="color:#ff7b72">${v}</span>`);
    renderLine(createLineEl(line), colored);
  }

  setTimeout(nextLine, 600);
</script>
